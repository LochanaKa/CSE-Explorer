# Auto-detect text files and normalize line endings to LF in the repository
* text=auto eol=lf

# Explicitly enforce LF for common web project files
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.md text eol=lf
*.json text eol=lf

# Treat images and binaries as binary (no line ending conversion)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.svg binary
*.ico binary
